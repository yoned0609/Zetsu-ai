{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "eval:dry-run": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "eval:live": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["ANTHROPIC_API_KEY"]
    }
  }
}
